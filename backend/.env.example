# =====================================================
# Backend - Variables de Entorno (EasyPanel / Desarrollo)
# Copiar como .env y completar los valores reales
# =====================================================

# Base de datos PostgreSQL
# En EasyPanel: usar el host interno (ejemplo: ollama_rapi-credi:5432)
# En local: postgres://postgres:PASSWORD@localhost:5432/posgres-db
DATABASE_URL=postgres://postgres:TU_PASSWORD@localhost:5432/rapicreditos_db

# JWT Secret — generar con: openssl rand -hex 32
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_MUY_SEGURO

# Puerto del servidor
PORT=3001

# Entorno (development / production)
NODE_ENV=development

# URL de la app (para redirects de pago y CORS)
APP_URL=http://localhost:8080

# IA - Ollama (instancia local o en la nube)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:0.5b
OPENWEBUI_URL=http://localhost:11434
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:0.5b
AI_BASE_URL=http://localhost:11434/api/generate

# IA - Groq (alternativa en la nube, más rápido)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# MercadoPago (Colombia) - https://www.mercadopago.com.co/developers
MERCADOPAGO_PUBLIC_KEY=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
MERCADOPAGO_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXX-XXXXXXXXXX

# PayPal (Internacional) - https://developer.paypal.com
PAYPAL_CLIENT_ID=TU_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=TU_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=sandbox
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
